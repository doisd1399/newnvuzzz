{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "node sanitize-firebase.mjs",
    "postinstall": "node sanitize-firebase.mjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:ranking-period": "node --import tsx/esm test_period_ranking.ts",
    "test:company-ranking-period": "node --import tsx/esm test_company_period_ranking.ts",
    "test:driver-scope-scores": "node --import tsx/esm ../test_driver_scope_scores.ts",
    "test:driver-scope-gap": "node --import tsx/esm ../test_driver_scope_gap.ts",
    "test:company-scope": "node --import tsx/esm ../test_company_scope_resolution.ts",
    "test:same-competitor-canonical": "node --import tsx/esm test_driver_same_competitor_canonical_totals.ts",
    "test:profile-ranking-alignment": "node --import tsx/esm ../test_profile_ranking_alignment_nvu8.ts"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-medium-image-zoom": "^5.4.6",
    "react-photo-view": "^1.2.7",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "firebase-tools": "^15.23.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
