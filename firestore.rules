rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSenior() {
      return isAuthenticated() && (
        ('role' in getUserData() && getUserData().role == 'senior') ||
        ('roles' in getUserData() && getUserData().roles.hasAny(['senior']))
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSenior() ||
        ('role' in getUserData() && getUserData().role == 'admin') ||
        ('roles' in getUserData() && getUserData().roles.hasAny(['admin']))
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allowed for initial setup
      allow update: if isAuthenticated() && (isOwner(userId) || isSenior() || isAdmin());
      allow delete: if isSenior();
    }

    // 2. frotas (companies)
    match /frotas/{id} {
      allow read: if true;
      allow create: if isAuthenticated(); 
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isSenior() || 
        isAdmin()
      );
    }

    // 3. veiculos
    match /veiculos/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 4. reboques
    match /reboques/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 5. contratos
    match /contratos/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 6. trabalhos
    match /trabalhos/{id} {
      allow read, write: if isAuthenticated();
    }

    // 7. solicitacoes_motoristas
    match /solicitacoes_motoristas/{id} {
      allow read, write: if isAuthenticated();
    }

    // 8. notificacoes
    match /notificacoes/{id} {
      allow read, write: if isAuthenticated();
    }

    // 9. jobDemands
    match /jobDemands/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 10. recruitment_applications
    match /recruitment_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // 11. company_registrations
    match /company_registrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // 12. companyMembers
    match /companyMembers/{id} {
      allow read, write: if isAuthenticated();
    }
    
    // Default fallback
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSenior();
    }
  }
}

