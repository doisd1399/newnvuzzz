rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSenior() {
      return isAuthenticated() && (
        ('role' in getUserData() && getUserData().role == 'senior') ||
        ('roles' in getUserData() && getUserData().roles.hasAny(['senior']))
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSenior() ||
        ('role' in getUserData() && getUserData().role == 'admin') ||
        ('roles' in getUserData() && getUserData().roles.hasAny(['admin']))
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allowed for initial setup
      allow update: if isAuthenticated() && (isOwner(userId) || isSenior() || isAdmin());
      allow delete: if isSenior();
    }

    // 2. frotas (companies)
    match /frotas/{id} {
      allow read: if true;
      allow create: if isAuthenticated(); 
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isSenior() || 
        isAdmin()
      );
    }

    // 3. veiculos
    match /veiculos/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 4. reboques
    match /reboques/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 5. contratos
    match /contratos/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 6. trabalhos
    match /trabalhos/{id} {
      allow read, write: if isAuthenticated();
    }

    // 7. solicitacoes_motoristas
    match /solicitacoes_motoristas/{id} {
      allow read, write: if isAuthenticated();
    }

    // 8. notificações internas (coleção atual + legado)
    // O cliente cria avisos em nome do usuário autenticado (actorUserId).
    // A leitura e a marcação como lida ficam restritas ao destinatário.
    match /notifications/{id} {
      allow create: if isAuthenticated() &&
        request.resource.data.userId is string &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.actorUserId == request.auth.uid
        );
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isSenior() || isAdmin());
    }

    match /notificacoes/{id} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isSenior() || isAdmin());
    }

    match /userDevices/{id} {
      allow create, update: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow read, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // 9. jobDemands
    match /jobDemands/{id} {
      allow read: if isAuthenticated();
      allow write: if isSenior() || isAdmin();
    }

    // 10. recruitment_applications
    match /recruitment_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // 11. company_registrations
    match /company_registrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // 12. companyMembers
    match /companyMembers/{id} {
      allow read, write: if isAuthenticated();
    }

    // 12b. simulator_members
    match /simulator_members/{id} {
      allow read, write: if isAuthenticated();
    }
    
    // 13. historico_viagens
    match /historico_viagens/{tripId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        (request.auth.token.role in ["admin", "owner"] &&
         request.auth.token.empresaId == resource.data.empresaId)
        ||
        (request.auth.token.role == "driver" &&
         request.auth.uid == resource.data.motoristaId)
      );
      allow delete: if request.auth != null && (
        (request.auth.token.role in ["admin", "owner"] &&
         request.auth.token.empresaId == resource.data.empresaId)
        ||
        (request.auth.token.role == "driver" &&
         request.auth.uid == resource.data.motoristaId)
      );
    }
    

    match /simulators/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    // Default fallback
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSenior();
    }
  }
}

